{
  "expo": {
    "name": "ViraChat",
    "slug": "ViraChat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.virachat"
    },
    "android": {
      "package": "com.virachat",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK"
      ]
    },
    "plugins": [],
    "scheme": "virachat"
  }
}
